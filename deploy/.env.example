# --- Local: docker compose -f deploy/docker-compose.yml --env-file deploy/.env ---
# Trên server production: GitHub Actions tự tạo deploy/.env (không cần clone repo).

TRACKING_BACKEND_IMAGE=ghcr.io/your_github_user/your_repo/tracking-backend:latest

POSTGRES_USER=tracking
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=tracking_db

TRACKING_API_KEY=change_me_long_random_api_key

API_PUBLIC_URL=https://tracking.david.io.vn

# ENABLE_SWAGGER=0
